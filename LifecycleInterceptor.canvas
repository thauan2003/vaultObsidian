		{"id":"167336d5ea39b794","type":"text","text":"O CDI ao ler o método, entende que o método possui um interceptador","x":-420,"y":-220,"width":305,"height":80},
		{"id":"23ee7a834dfe9e89","type":"text","text":"Se sim: Commit()","x":-20,"y":170,"width":250,"height":60},
